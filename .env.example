# AgentLamp environment — copy to .env and fill in. NEVER commit .env.
# Secrets (collector secret, device token) live in the OS keyring / device NVS,
# NOT here. This file is non-secret config only.

# ---- Mode ----
AGENTLAMP_MODE=local            # local | relay

# ---- Local mode ----
AGENTLAMP_LOCAL_BIND=0.0.0.0:8787    # LAN address the frame server binds

# ---- Aliases (path -> display alias; keeps real names off any upload) ----
# Prefer ~/.config/agentlamp/aliases.toml; this is only the file location.
AGENTLAMP_ALIAS_FILE=~/.config/agentlamp/aliases.toml

# ---- Relay mode (only if AGENTLAMP_MODE=relay) ----
# Collector secret + key id are stored in the OS keyring, not here.
AGENTLAMP_RELAY_BASE_URL=        # e.g. https://orb.example.com
AGENTLAMP_COLLECTOR_ID=          # ^[A-Za-z0-9_-]{1,64}$
AGENTLAMP_KEY_ID=                # kid selecting the active collector secret

# ---- Retention (days) ----
AGENTLAMP_EVENT_RETENTION_DAYS=30
